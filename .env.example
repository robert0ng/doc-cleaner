# doc-cleaner environment variables
# Copy this to .env and fill in your values

# Gemini API key (required for --ai gemini)
GEMINI_API_KEY=

# Groq API key (required for --ai groq)
GROQ_API_KEY=

# PDF decryption password (optional, or use --password CLI arg)
PDF_PASSWORD=

# Gmail attachment fetcher — OAuth2 (no API key needed)
# Download credentials.json from Google Cloud Console (Gmail API, Desktop app type).
# First run opens a browser for consent; token.json is cached for subsequent runs.
